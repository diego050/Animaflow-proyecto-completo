# ============================================
# AnimaFlow — Environment Variables Template
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Environment
ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/animaflow

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secrets (generate strong random values for production)
SECRET_KEY=change-me-in-production-min-32-chars
ENCRYPTION_KEY=change-me-in-production-min-32-chars

# LLM — Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite-preview

# TTS — Voicebox
VOICEBOX_URL=http://127.0.0.1:17493

# Storage (paths inside Docker container)
STORAGE_BASE_DIR=/app
STORAGE_PATH=./storage
AUDIO_STORAGE_PATH=./storage/audio
VIDEO_STORAGE_PATH=./storage/videos

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend API URL (for frontend .env)
VITE_API_BASE_URL=http://localhost:8000
 