# ============================================
# ANIMAFLOW - Environment Configuration
# ============================================

# Environment (development | testing | production)
ENV=development

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/animaflow

# ============================================
# Redis (for RQ queues)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# Security (REQUIRED)
# ============================================
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-64-character-hex-string-in-production

# Generate ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-this-to-a-32-byte-base64-fernet-key

# JWT Token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================
# CORS (comma-separated origins)
# ============================================
# Development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Production (uncomment and update)
# CORS_ORIGINS=https://yourdomain.com

# ============================================
# LLM / AI Providers
# ============================================
# Google Gemini (for script generation, visual specs)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# OpenCode (optional alternative)
# OPENCODE_API_KEY=your-opencode-api-key
# OPENCODE_MODEL=minimax-m2.5
# OPENCODE_BASE_URL=https://api.opencode.ai/v1

# ============================================
# TTS (Text-to-Speech)
# ============================================
# Default TTS provider: local_piper | elevenlabs | google_tts | gemini_tts
TTS_PROVIDER=local_piper

# For external TTS providers (users add their own API keys in settings)
# ELEVENLABS_API_KEY=your-elevenlabs-key
# GOOGLE_TTS_API_KEY=your-google-tts-key

# ============================================
# Storage Paths
# ============================================
STORAGE_PATH=./storage
AUDIO_STORAGE_PATH=./storage/audio
VIDEO_STORAGE_PATH=./storage/videos

# ============================================
# Resend (contact form emails)
# ============================================
RESEND_API_KEY=your-resend-api-key-here
RESEND_TO_EMAIL=admin@yourdomain.com

# ============================================
# Frontend URL (for redirects, emails)
# ============================================
FRONTEND_URL=http://localhost:3000
