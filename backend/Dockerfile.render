FROM nikolaik/python-nodejs:python3.11-nodejs20-slim

WORKDIR /app

# Instalar dependencias del sistema para Chromium y FFmpeg
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libnss3 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    libxss1 \
    libasound2 \
    libxtst6 \
    ca-certificates \
    fonts-liberation \
    libappindicator3-1 \
    libcurl4 \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Instalar dependencias Python del backend
COPY backend/requirements.txt ./requirements.txt

# Install torch CPU-only first (prevents openai-whisper from downloading CUDA libs)
RUN pip install torch --index-url https://download.pytorch.org/whl/cpu

RUN pip install --no-cache-dir -r requirements.txt

# Copiar código del backend
COPY backend/ ./

# Crear punto de montaje para volumen compartido de componentes generados
RUN mkdir -p /app/frontend/src/remotion/generated

# Copiar frontend e instalar dependencias Node (necesario para Remotion CLI)
COPY frontend/package*.json /app/frontend/
RUN cd /app/frontend && npm ci

# Copiar el resto del frontend
COPY frontend/ /app/frontend/

# Asegurar descarga del navegador Chromium para Remotion
RUN cd /app/frontend && npx remotion browser ensure

# Crear directorios de storage
RUN mkdir -p /app/storage/assets /app/storage/audio /app/storage/videos /app/storage/models

# Create non-root user, handling case where UID 1000 already exists
RUN if ! id -u appuser >/dev/null 2>&1; then \
        useradd -m appuser || useradd -m -u 1001 appuser; \
    fi
RUN chown -R appuser:appuser /app/frontend /app/storage || true
USER appuser

# Comando por defecto: worker de render
CMD ["python", "-m", "worker", "--queues", "render"]
