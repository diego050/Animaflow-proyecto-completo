# === Node / Frontend ===
node_modules/
/frontend/dist
/frontend/dist-ssr
/frontend/out
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache
/frontend/.env
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local

# === Remotion / Video ===
# Ignoramos los videos generados
*.mp4
*.webm
*.wav
*.mp3

# Ignoramos la carpeta de Voicebox (archivos temporales de audio/modelos)
voicebox/

# Ignoramos storage/ (datos de usuario, modelos, caché)
/storage/*
!/storage/.gitkeep

# Ignoramos los componentes dinámicos generados por el pipeline

# para que no contaminen tu repositorio de Git con archivos de pruebas
/frontend/src/remotion/generated/*
!/frontend/src/remotion/generated/.gitkeep

# === IDEs / Sistema ===
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# === Debug / LLM Output ===
/backend/storage/debug/*
!/backend/storage/debug/.gitkeep

# === Security Reports ===
security_reports/*.html
security_reports/*.md
!security_reports/.gitkeep

# === Temporary / Generated ===
docs/temp/

# opencode config with sensitive API tokens
opencode.json
